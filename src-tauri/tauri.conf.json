{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mix Files",
  "version": "1.5.6",
  "identifier": "com.tuanndpersonallab.mixfiles",
  "build": {
    "frontendDist": "../src-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mix Files",
        "width": 980,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Shuffle MP3 files into folders",
    "longDescription": "Create multiple output folders from one source folder of MP3 files with shuffled order and optional numeric prefixes.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
